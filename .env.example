# ================================
# GMAO Pro — Environment Variables
# ================================
# Copy this file to .env and fill in your values

# --- Node ---
NODE_ENV=development
PORT=4000

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=gmao
DB_PASSWORD=gmao_secret
DB_NAME=gmao_db
DATABASE_URL="postgresql://gmao:gmao_secret@localhost:5432/gmao_db"

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Frontend ---
FRONTEND_URL=http://localhost:5173

# --- Logging ---
LOG_LEVEL=info

# --- S3 Storage (MinIO) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=gmao_admin
MINIO_SECRET_KEY=gmao_secret_minio
MINIO_BUCKET_NAME=gmao-media
