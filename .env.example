# ══════════════════════════════════════════════════════════════════
#  GMAO Pro — Configuration Docker
#  1. Copier ce fichier : cp .env.example .env
#  2. Modifier les valeurs marquées CHANGEME
#  3. Lancer : ./run.sh
# ══════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────
# Port d'accès à l'application (http://localhost:APP_PORT)
APP_PORT=80
FRONTEND_URL=http://localhost
NODE_ENV=production
LOG_LEVEL=info

# ─── Base de données PostgreSQL ───────────────────────────────────
POSTGRES_DB=gmao
POSTGRES_USER=gmao_user
POSTGRES_PASSWORD=CHANGEME_mot_de_passe_base_de_donnees

# ─── Sécurité JWT ─────────────────────────────────────────────────
# OBLIGATOIRE : chaîne aléatoire d'au moins 32 caractères
# Générer avec : openssl rand -hex 32
JWT_SECRET=CHANGEME_jwt_secret_must_be_at_least_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Stockage MinIO (S3-compatible) ───────────────────────────────
MINIO_ACCESS_KEY=gmao_admin
MINIO_SECRET_KEY=CHANGEME_mot_de_passe_minio
MINIO_BUCKET_NAME=gmao-media
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Données de démonstration ─────────────────────────────────────
# Mettre à true pour injecter des données démo au premier démarrage
SEED_DB=false
